<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BrewApp.Models.Sales"
             xmlns:vm="clr-namespace:BrewApp.PageModels.Sales"
             x:Class="BrewApp.Pages.Sales.SalesOrderDetailPage"
             x:DataType="vm:SalesOrderDetailPageModel"
             Title="Order Details">
    <ScrollView>
        <StackLayout Padding="16" Spacing="16">
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" VerticalOptions="Center"/>
            <StackLayout IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" Spacing="12">
                <Frame Padding="16" CornerRadius="8" HasShadow="True">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="120,*">
                        <Label Grid.Row="0" Grid.Column="0" Text="Order Number:" FontAttributes="Bold"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding SalesOrder.OrderNumber}"/>
                        <Label Grid.Row="1" Grid.Column="0" Text="Status:" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding SalesOrder.Status}" Margin="0,8,0,0"/>
                        <Label Grid.Row="2" Grid.Column="0" Text="Customer:" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding SalesOrder.CustomerName}" Margin="0,8,0,0"/>
                        <Label Grid.Row="3" Grid.Column="0" Text="Customer ID:" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding SalesOrder.CustomerId}" Margin="0,8,0,0"/>
                        <Label Grid.Row="4" Grid.Column="0" Text="Order Date:" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding SalesOrder.OrderDate, StringFormat='{0:yyyy-MM-dd}'}" Margin="0,8,0,0"/>
                        <Label Grid.Row="5" Grid.Column="0" Text="Delivery Date:" FontAttributes="Bold" Margin="0,8,0,0"/>
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding SalesOrder.DeliveryDate, StringFormat='{0:yyyy-MM-dd}'}" Margin="0,8,0,0"/>
                    </Grid>
                </Frame>
                <Label Text="Order Items" FontSize="20" FontAttributes="Bold" Margin="0,8,0,0"/>
                <CollectionView ItemsSource="{Binding SalesOrder.Rows}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SalesOrderRow">
                            <Frame Margin="0,4" Padding="12" CornerRadius="8">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="100,*">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Beer:" FontAttributes="Bold"/>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding BeerName}"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="Beer ID:" FontAttributes="Bold" Margin="0,4,0,0"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding BeerId}" Margin="0,4,0,0"/>
                                    <Label Grid.Row="2" Grid.Column="0" Text="Quantity:" FontAttributes="Bold" Margin="0,4,0,0"/>
                                    <Label Grid.Row="2" Grid.Column="1" Margin="0,4,0,0">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Quantity.Value"/>
                                                <Binding Path="Quantity.UnitOfMeasure"/>
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Grid.Row="3" Grid.Column="0" Text="Price:" FontAttributes="Bold" Margin="0,4,0,0"/>
                                    <Label Grid.Row="3" Grid.Column="1" Margin="0,4,0,0">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Price.Value"/>
                                                <Binding Path="Price.Currency"/>
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </StackLayout>
    </ScrollView>
</ContentPage>
