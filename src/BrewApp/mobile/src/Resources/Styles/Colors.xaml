<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary brand colors for brewery app -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="Secondary">#D97706</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>
    
    <!-- Background colors -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Semantic colors -->
    <Color x:Key="Success">#28A745</Color>
    <Color x:Key="Warning">#FFC107</Color>
    <Color x:Key="Error">#DC3545</Color>
    <Color x:Key="Info">#17A2B8</Color>

    <!-- Card/Component colors -->
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBorder">#E1E1E1</Color>

</ResourceDictionary>
