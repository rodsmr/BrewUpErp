<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BrewApp.Models.Sales"
             xmlns:vm="clr-namespace:BrewApp.PageModels.Sales"
             x:Class="BrewApp.Pages.Sales.CreateSalesOrderPage"
             x:DataType="vm:CreateSalesOrderPageModel"
             Title="Create Sales Order">
    <ScrollView>
        <StackLayout Padding="16" Spacing="16">
            <Frame Padding="16" CornerRadius="8" HasShadow="True">
                <StackLayout Spacing="12">
                    <Label Text="Order Information" FontSize="18" FontAttributes="Bold"/>
                    <Label Text="Order Number"/>
                    <Entry Text="{Binding OrderNumber}" Placeholder="Enter order number"/>
                    <Label Text="Order Date"/>
                    <DatePicker Date="{Binding OrderDate}"/>
                    <Label Text="Delivery Date"/>
                    <DatePicker Date="{Binding DeliveryDate}"/>
                </StackLayout>
            </Frame>
            <Frame Padding="16" CornerRadius="8" HasShadow="True">
                <StackLayout Spacing="12">
                    <Label Text="Customer Information" FontSize="18" FontAttributes="Bold"/>
                    <Label Text="Customer ID"/>
                    <Entry Text="{Binding CustomerId}" Placeholder="Enter customer ID"/>
                    <Label Text="Customer Name"/>
                    <Entry Text="{Binding CustomerName}" Placeholder="Enter customer name"/>
                </StackLayout>
            </Frame>
            <Frame Padding="16" CornerRadius="8" HasShadow="True">
                <StackLayout Spacing="12">
                    <HorizontalStackLayout>
                        <Label Text="Order Items" FontSize="18" FontAttributes="Bold" HorizontalOptions="StartAndExpand"/>
                        <Button Text="Add Item" Command="{Binding AddRowCommand}"/>
                    </HorizontalStackLayout>
                    <CollectionView ItemsSource="{Binding Rows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SalesOrderRow">
                                <Frame Margin="0,8" Padding="12" CornerRadius="8" BorderColor="LightGray">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,40">
                                        <Label Grid.Row="0" Grid.Column="0" Text="Beer ID"/>
                                        <Entry Grid.Row="1" Grid.Column="0" Text="{Binding BeerId}" Placeholder="Enter beer ID"/>
                                        <Label Grid.Row="2" Grid.Column="0" Text="Beer Name"/>
                                        <Entry Grid.Row="3" Grid.Column="0" Text="{Binding BeerName}" Placeholder="Enter beer name"/>
                                        <Grid Grid.Row="4" Grid.Column="0" ColumnDefinitions="*,*">
                                            <StackLayout Grid.Column="0" Margin="0,0,4,0">
                                                <Label Text="Quantity"/>
                                                <Entry Text="{Binding Quantity.Value}" Keyboard="Numeric" Placeholder="0"/>
                                            </StackLayout>
                                            <StackLayout Grid.Column="1" Margin="4,0,0,0">
                                                <Label Text="Unit"/>
                                                <Entry Text="{Binding Quantity.UnitOfMeasure}" Placeholder="Bottles"/>
                                            </StackLayout>
                                        </Grid>
                                        <Grid Grid.Row="5" Grid.Column="0" ColumnDefinitions="*,*">
                                            <StackLayout Grid.Column="0" Margin="0,0,4,0">
                                                <Label Text="Price"/>
                                                <Entry Text="{Binding Price.Value}" Keyboard="Numeric" Placeholder="0.00"/>
                                            </StackLayout>
                                            <StackLayout Grid.Column="1" Margin="4,0,0,0">
                                                <Label Text="Currency"/>
                                                <Entry Text="{Binding Price.Currency}" Placeholder="EUR"/>
                                            </StackLayout>
                                        </Grid>
                                        <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="6" Text="?" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreateSalesOrderPageModel}}, Path=RemoveRowCommand}" CommandParameter="{Binding .}" BackgroundColor="Red" TextColor="White" VerticalOptions="Center"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Frame>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="Cancel" Command="{Binding CancelCommand}" BackgroundColor="Gray"/>
                <Button Grid.Column="1" Text="Save Order" Command="{Binding SaveOrderCommand}" IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"/>
            </Grid>
            <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}" HorizontalOptions="Center"/>
        </StackLayout>
    </ScrollView>
</ContentPage>
