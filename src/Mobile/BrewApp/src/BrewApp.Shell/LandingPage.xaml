<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BrewApp.Shell.LandingPage"
             Title="Home">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="200"
                Aspect="AspectFit"
                SemanticProperties.Description="Brewery themed placeholder image" />

            <Label
                Text="{Binding Title}"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                Text="{Binding Subtitle}"
                FontSize="16"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Margin="0,0,0,24" />

            <Label
                Text="Use the menu to navigate to Master Data, Sales, Warehouse and Purchase modules."
                FontSize="14"
                HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
