@page "/masterdata/customers"
@using BrewSpa.Shared.Components.Components
@using Microsoft.AspNetCore.Components.QuickGrid

<PageTitle>Customers</PageTitle>

<div class="customers-container">
    @* <div class="header-section"> *@
    @*     <h1 class="page-title">Customers</h1> *@
    @*     <p class="page-subtitle">Manage customer information and contacts</p> *@
    @* </div> *@
    
    <Toolbar CurrentContext="@_currentContext"/>

    @if (_isLoading)
    {
        <div class="loading-spinner">
            <div class="spinner"></div>
            <p>Loading customers...</p>
        </div>
    }
    else if (_customers.Any())
    {
        <div class="grid-container">
            <QuickGrid ItemsProvider="@_gridItemsProvider" Pagination="@_pagination" ItemKey="@(c => c.CustomerId)">
                <PropertyColumn Title="ID" Property="@(c => c.CustomerId)" />
                <PropertyColumn Title="Ragione Sociale" Property="@(c => c.RagioneSociale)" Sortable="true">
                    <ColumnOptions>
                        <div class="search-box">
                            <input type="search" autofocus @bind="_nameFilter" @bind:event="oninput" placeholder="Ragione Sociale..."/>
                        </div>
                    </ColumnOptions>
                </PropertyColumn>
                <PropertyColumn Title="Partita IVA" Property="@(c => c.PartitaIva)"/>
                <PropertyColumn Title="Consumer Level" Property="@(c => c.ConsumerLevel)" Sortable="true"/>
            </QuickGrid>
        </div>
        <Paginator State="@_pagination" />
    }
    else
    {
        <div class="no-data">
            <i class="fas fa-users fa-3x"></i>
            <h3>No customers found</h3>
            <p>Click the Add button to create your first customer.</p>
        </div>
    }
</div>

<AddCustomer 
    IsVisible="_showDialog" 
    Customer="_selectedCustomer"
    OnSubmit="OnDialogSubmit"
    OnCancel="OnDialogCancel" />