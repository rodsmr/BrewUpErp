@using BitBlazor
@using BitBlazor.Components
@using BrewSpa.Shared.Components.CustomTypes

<div class="py-2 px-2">
    <div class="mb-2">
        <BitButton Color="Color.Primary" OnClick="@(async () => await ButtonClicked(ToolbarButtons.AddNewItem))">
            <i class="fas fa-plus"></i> Add
        </BitButton>
        <BitButton Color="Color.Secondary" Icon="fa-sync" OnClick="@(async () => await ButtonClicked(ToolbarButtons.Refresh))">
            <i class="fas fa-sync"></i> Refresh
        </BitButton>
        <BitButton Color="Color.Secondary" OnClick="@(async () => await ButtonClicked(ToolbarButtons.Close))">
            <i class="fas fa-times"></i> Close
        </BitButton>
    </div>
</div>