<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BrewApp.Mobile.Models"
             x:Class="BrewApp.Mobile.Components.OrderListItem"
             x:DataType="models:Order">
    <Border Padding="12" 
            Margin="8,4"
            BackgroundColor="{DynamicResource CardBackground}"
            Stroke="{DynamicResource CardBorder}"
            StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12">
            <!-- Order ID -->
            <Label Grid.Row="0" Grid.Column="0"
                   Text="{Binding OrderId, StringFormat='Order #{0}'}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}" />
            
            <!-- Status Badge -->
            <Border Grid.Row="0" Grid.Column="1"
                    Padding="8,4"
                    BackgroundColor="{DynamicResource Secondary}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4" />
                </Border.StrokeShape>
                <Label Text="{Binding Status}"
                       FontSize="12"
                       TextColor="White" />
            </Border>
            
            <!-- Customer Name -->
            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="{Binding CustomerName}"
                   FontSize="14"
                   TextColor="{DynamicResource Gray600}"
                   Margin="0,4,0,0" />
            
            <!-- Order Date -->
            <Label Grid.Row="2" Grid.Column="0"
                   Text="{Binding OrderDate, StringFormat='Ordered: {0:d MMM yyyy}'}"
                   FontSize="13"
                   TextColor="{DynamicResource Gray500}"
                   Margin="0,4,0,0" />
            
            <!-- Total Amount -->
            <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="{Binding TotalAmount, StringFormat='Total: ${0:F2}'}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}"
                   Margin="0,8,0,0" />
        </Grid>
    </Border>
</ContentView>
