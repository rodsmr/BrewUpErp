@page "/sales"

<PageTitle>Sales</PageTitle>

<div class="sales-container">
    <div class="header-section">
        <h1 class="page-title">Sales Management</h1>
        <p class="page-subtitle">Manage orders, customers, and sales performance</p>
    </div>

    <div class="tiles-grid">
        <div class="tile tile-orders" @onclick="@(() => NavigateToSection("orders"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
            </div>
            <h2 class="tile-title">Orders</h2>
            <p class="tile-description">Create and manage customer orders</p>
        </div>

        <div class="tile tile-summary" @onclick="@(() => NavigateToSection("summary"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                    <path d="M9 9h6v6H9z"></path>
                    <line x1="9" y1="3" x2="9" y2="21"></line>
                    <line x1="15" y1="3" x2="15" y2="21"></line>
                </svg>
            </div>
            <h2 class="tile-title">Summary</h2>
            <p class="tile-description">View sales overview and key metrics</p>
        </div>

        <div class="tile tile-invoices" @onclick="@(() => NavigateToSection("invoices"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="12" y1="19" x2="12" y2="12"></line>
                    <line x1="9" y1="16" x2="15" y2="16"></line>
                </svg>
            </div>
            <h2 class="tile-title">Invoices</h2>
            <p class="tile-description">Generate and manage invoices</p>
        </div>

        <div class="tile tile-quotes" @onclick="@(() => NavigateToSection("quotes"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
            </div>
            <h2 class="tile-title">Quotes</h2>
            <p class="tile-description">Create and track sales quotes</p>
        </div>

        <div class="tile tile-customers" @onclick="@(() => NavigateToSection("customers"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
            </div>
            <h2 class="tile-title">Customers</h2>
            <p class="tile-description">Manage customer accounts and information</p>
        </div>

        <div class="tile tile-returns" @onclick="@(() => NavigateToSection("returns"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 7 3 17 17 17 17 7"></polyline>
                    <rect x="5" y="3" width="14" height="4"></rect>
                    <path d="M10 12v5"></path>
                    <path d="M14 12v5"></path>
                </svg>
            </div>
            <h2 class="tile-title">Returns</h2>
            <p class="tile-description">Process and track returns and refunds</p>
        </div>

        <div class="tile tile-performance" @onclick="@(() => NavigateToSection("performance"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                </svg>
            </div>
            <h2 class="tile-title">Performance</h2>
            <p class="tile-description">Analyze sales metrics and KPIs</p>
        </div>

        <div class="tile tile-activities" @onclick="@(() => NavigateToSection("activities"))">
            <div class="tile-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm3.5 6c0 1.93-1.57 3.5-3.5 3.5S8.5 13.93 8.5 12 10.07 8.5 12 8.5s3.5 1.57 3.5 3.5z"></path>
                </svg>
            </div>
            <h2 class="tile-title">Activities</h2>
            <p class="tile-description">Track customer interactions and follow-ups</p>
        </div>
    </div>
</div>

@code {
    private void NavigateToSection(string section)
    {
        // Navigation logic to be implemented
        // This will handle navigation to the respective sales sections
        _ = section; // For future implementation
    }
}

