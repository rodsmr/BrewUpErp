<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BrewApp.Models.Sales"
             xmlns:vm="clr-namespace:BrewApp.PageModels.Sales"
             x:Class="BrewApp.Pages.Sales.SalesOrderListPage"
             x:DataType="vm:SalesOrderListPageModel"
             Title="Sales Orders">
    <Grid RowDefinitions="Auto,*">
        <HorizontalStackLayout Grid.Row="0" Padding="16" Spacing="10">
            <Button Text="Create Order" Command="{Binding NavigateToCreateOrderCommand}" HorizontalOptions="End"/>
        </HorizontalStackLayout>
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" VerticalOptions="Center"/>
        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}" IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView ItemsSource="{Binding SalesOrders}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <StackLayout Padding="20" VerticalOptions="Center">
                        <Label Text="No sales orders found" HorizontalOptions="Center" FontSize="18" TextColor="Gray"/>
                    </StackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SalesOrder">
                        <Frame Margin="16,8" Padding="16" CornerRadius="8" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SalesOrderListPageModel}}, Path=NavigateToOrderDetailCommand}" CommandParameter="{Binding Id}"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding OrderNumber}" FontSize="18" FontAttributes="Bold"/>
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Status}" FontSize="14" TextColor="Green" VerticalOptions="Center"/>
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding CustomerName}" FontSize="16" Margin="0,4,0,0"/>
                                <Label Grid.Row="2" Grid.Column="0" Text="{Binding OrderDate, StringFormat='Order Date: {0:yyyy-MM-dd}'}" FontSize="14" TextColor="Gray" Margin="0,4,0,0"/>
                                <Label Grid.Row="3" Grid.Column="0" Text="{Binding DeliveryDate, StringFormat='Delivery: {0:yyyy-MM-dd}'}" FontSize="14" TextColor="Gray" Margin="0,4,0,0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
